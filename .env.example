# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# Hack Club Auth (OAuth / OIDC)
# Create app at https://auth.hackclub.com/developer/apps
# Callback URL: {BETTER_AUTH_URL}/api/auth/oauth2/callback/hackclub
HACKCLUB_CLIENT_ID=""
HACKCLUB_CLIENT_SECRET=""

